# URL del API (la usa el NAVEGADOR). Déjalo RELATIVO para que el navegador llame a
# su propio origen y el dev server / contenedor web haga de proxy al API. Así también
# funciona para clientes remotos (VPN/LAN). Solo ponlo absoluto si sirves el API en
# otro dominio (p.ej. Railway con servicios separados).
VITE_API_URL=/api/v1

# Firebase (Google Sign-In en web). Cópialos de la consola de Firebase →
# Configuración del proyecto → Tus apps → app web.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Opcional: mapas
VITE_GOOGLE_MAPS_API_KEY=
