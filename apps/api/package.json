{
  "name": "@yourvivac/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:workers": "tsx watch src/workers/index.ts",
    "start": "node dist/server.js",
    "start:workers": "node dist/workers/index.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.25.0",
    "@yourvivac/types": "workspace:*",
    "@yourvivac/utils": "workspace:*",
    "@yourvivac/validation": "workspace:*",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "cheerio": "^1.0.0",
    "cloudinary": "^2.5.1",
    "sanitize-html": "^2.13.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.6.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "nodemailer": "^6.9.15",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "rate-limit-redis": "^4.2.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.16",
    "@types/node": "^20.14.0",
    "@types/sanitize-html": "^2.13.0",
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
