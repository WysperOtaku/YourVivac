# YourVivac — variables de entorno (ver Guía de desarrollo §16)
# Copia a .env y rellena. NUNCA commitees el .env real.

# --- API ---
PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/yourvivac
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Firebase (OAuth Google, verificación con firebase-admin) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email (Brevo via Nodemailer) ---
BREVO_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="YourVivac <no-reply@yourvivac.app>"

# --- Microservicio de tiendas (Cordal) — proxy ---
STORE_SERVICE_URL=http://localhost:5000
STORE_SERVICE_API_KEY=

# --- Mapas ---
GOOGLE_MAPS_API_KEY=

# --- Seguridad ---
CORS_ORIGINS=http://localhost:5173,http://localhost:19006
MODERATION_PROVIDER_KEY=
# Cookie de refresh. Local (http): secure=false, samesite=lax.
# Railway/producción (https, web y API en dominios distintos): secure=true, samesite=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Web (Vite, prefijo VITE_) ---
# Relativo: el navegador llama a su propio origen y la web hace de proxy al API.
VITE_API_URL=/api/v1
VITE_GOOGLE_MAPS_API_KEY=
# Firebase web (Google Sign-In). Consola Firebase → Config. del proyecto → app web.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
